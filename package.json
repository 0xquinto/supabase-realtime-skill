{
  "name": "supabase-realtime-skill",
  "version": "0.1.0",
  "description": "Agent Skill + MCP server for Supabase Realtime/CDC. Bounded subscription pattern fits Edge Function isolate budgets.",
  "license": "Apache-2.0",
  "author": "Diego Gomez <diego.gomez210@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xquinto/supabase-realtime-skill.git"
  },
  "homepage": "https://github.com/0xquinto/supabase-realtime-skill#readme",
  "bugs": {
    "url": "https://github.com/0xquinto/supabase-realtime-skill/issues"
  },
  "keywords": [
    "supabase",
    "realtime",
    "mcp",
    "agent-skill",
    "agent",
    "postgres",
    "cdc",
    "edge-functions"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    }
  },
  "files": ["dist", "SKILL.md", "references", "manifest.json"],
  "scripts": {
    "build": "bun build src/client/index.ts --outdir dist/client --target node && bun build src/client/index.ts --outfile dist/client/index.cjs --target node --format cjs && bun build src/server/index.ts --outdir dist/server --target node && bun build src/server/index.ts --outfile dist/server/index.cjs --target node --format cjs",
    "test:fast": "vitest run --project fast",
    "test:smoke": "vitest run --project smoke --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "postgres": "^3.4.9",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
